# ============================================================
# AI 브리핑 에이전트 환경변수 설정
# 이 파일을 복사해서 .env를 만든 뒤 값을 채워 넣으세요.
# cp .env.example .env
# ============================================================

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Zapier MCP 인증 토큰 (Zapier MCP 설정 페이지에서 발급)
ZAPIER_AUTH=

# 이메일 수신자 주소
EMAIL_TO=
